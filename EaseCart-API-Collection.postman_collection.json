              "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"This is a new product description\",\n  \"price\": 99.99,\n  \"category\": \"electronics\",\n  \"stock\": 50,\n  \"images\": [\n    {\n      \"url\": \"https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=500\",\n      \"alt\": \"Product Image\"\n    }\n  ],\n  \"brand\": \"TechBrand\",\n  \"weight\": 0.5,\n  \"dimensions\": {\n    \"length\": 20,\n    \"width\": 15,\n    \"height\": 5\n  },\n  \"tags\": [\"new\", \"featured\", \"electronics\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
